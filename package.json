{
  "name": "reader",
  "private": true,
  "version": "0.1.48",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "clean": "npm run clean:knip && npm run clean:css",
    "clean:knip": "knip --fix",
    "clean:css": "purgecss --config ./purgecss.config.js --output ./dist/assets",
    "clean:dist": "rimraf dist",
    "preview": "vite preview",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "dexie": "^4.0.9",
    "openai": "^4.67.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "knip": "^6.4.1",
    "purgecss": "^8.0.0",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
